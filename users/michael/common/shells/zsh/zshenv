# Fallback TERM if terminal emulator doesn't set it (needed before zellij auto-start)
export TERM="${TERM:-xterm-256color}"

# LESSOPEN is set here because lesspipe.enable doesn't know about our custom .lessfilter
export LESSOPEN='|~/.config/.lessfilter %s'

export SOPS_AGE_KEY_FILE="$HOME/.config/sops/age/keys.txt"
